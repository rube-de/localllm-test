# Turso (libSQL). For local dev use a file URL: file:./local.db
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# Admin auth. Generate the env line with:
#   bun scripts/hash-password.ts <plain>
# Note: the script outputs the hash with $ chars escaped as \$ so Bun/Vite env
# loaders do not interpret them as variable references. Paste the printed line
# (including the \$ escapes) verbatim.
ADMIN_PASSWORD_HASH=

# 32-byte hex string. Generate with: openssl rand -hex 32
SESSION_SECRET=
